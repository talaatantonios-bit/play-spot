generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String
  password   String
  coinsCount Int      @default(0) @map("coins_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  role       Role     @default(USER)

  coinTransactions CoinTransaction[]
  shop             Shop?

  @@map("users")
}

model Shop {
  id          String  @id @default(uuid())
  name        String
  description String?
  logoUrl     String? @map("logo_url")
  ownerId    Int    @unique @map("owner_id")
  owner      User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerEmail String @map("owner_email")

  subscriptionStart  DateTime?          @map("subscription_start")
  subscriptionEnd    DateTime?          @map("subscription_end")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  subscriptionPlan   SubscriptionPlan   @default(basic) @map("subscription_plan")

  phoneNumber   String?  @map("phone_number")
  isActive      Boolean  @default(true) @map("is_active")
  isBlocked     Boolean  @default(false) @map("is_blocked")
  blockedReason String?  @map("blocked_reason")

  totalBranches Int @default(0) @map("total_branches")
  totalDevices  Int @default(0) @map("total_devices")
  totalBookings Int @default(0) @map("total_bookings")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")

  branches Branch[]

  @@index([ownerId])
  @@index([subscriptionStatus])
  @@index([isActive, subscriptionStatus])
  @@map("shops")
}

model Branch {
  id          String  @id @default(uuid())

  shopId      String  @map("shop_id")
  shop        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String
  description String?

  address       String
  city          String
  area          String
  latitude      Float?
  longitude     Float?
  googleMapsUrl String? @map("google_maps_url")
  imageUrl      String? @map("image_url")
  phoneNumber   String? @map("phone_number")

  operatingHours Json?    @map("operating_hours")

  isActive     Boolean @default(true) @map("is_active")
  totalDevices Int     @default(0)    @map("total_devices")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([shopId, isActive])
  @@index([city, isActive])
  @@map("branches")
}

model CoinTransaction {
  id              Int                    @id @default(autoincrement())
  amount          Int
  userId          Int                    @map("user_id")
  description     TransactionDescription
  transactionType TransactionType        @map("transaction_type")
  createdAt       DateTime               @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("coin_transactions")
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  imageUrl     String?  @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  locale       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum Role {
  USER
  SUPER_ADMIN
  SHOP_ADMIN
}

enum TransactionType {
  Debit
  Credit
}

enum TransactionDescription {
  New_User     @map("New user")
  Daily_Reward @map("Daily Reward")
  Ad_Reward    @map("Ad Reward")
  Booking
}

enum SubscriptionStatus {
  trial
  active
  expired
  cancelled
}

enum SubscriptionPlan {
  basic
  pro
  enterprise
}
