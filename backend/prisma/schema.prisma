generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String
  password   String
  coinsCount Int      @default(0) @map("coins_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  role       Role     @default(USER)

  coinTransactions CoinTransaction[]
  shop             Shop?

  @@map("users")
}

model Shop {
  id          String  @id @default(uuid())
  name        String
  description String?
  logoUrl     String? @map("logo_url")
  ownerId    Int    @unique @map("owner_id")
  owner      User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerEmail String @map("owner_email")

  subscriptionStart  DateTime?          @map("subscription_start")
  subscriptionEnd    DateTime?          @map("subscription_end")
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  subscriptionPlan   SubscriptionPlan   @default(basic) @map("subscription_plan")

  phoneNumber   String?  @map("phone_number")
  isActive      Boolean  @default(true) @map("is_active")
  isBlocked     Boolean  @default(false) @map("is_blocked")
  blockedReason String?  @map("blocked_reason")

  totalBranches Int @default(0) @map("total_branches")
  totalDevices  Int @default(0) @map("total_devices")
  totalBookings Int @default(0) @map("total_bookings")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")

  branches Branch[]
  devices  Device[]

  @@index([ownerId])
  @@index([subscriptionStatus])
  @@index([isActive, subscriptionStatus])
  @@map("shops")
}

model Branch {
  id          String  @id @default(uuid())

  shopId      String  @map("shop_id")
  shop        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String
  description String?

  address       String
  city          String
  area          String
  latitude      Float?
  longitude     Float?
  googleMapsUrl String? @map("google_maps_url")
  imageUrl      String? @map("image_url")
  phoneNumber   String? @map("phone_number")

  operatingHours Json?    @map("operating_hours")

  isActive     Boolean @default(true) @map("is_active")
  totalDevices Int     @default(0)    @map("total_devices")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  devices Device[]

  @@index([shopId, isActive])
  @@index([city, isActive])
  @@map("branches")
}

model Device {
  id          String   @id @default(uuid())

  // Parent Relations
  shopId      String   @map("shop_id")
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branchId    String   @map("branch_id")
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Device Info
  name                   String
  deviceNumber           String?      @map("device_number")
  deviceType             DeviceType   @map("device_type")
  roomHourlyPrice        Int?          @map("room_hourly_price")
  singleHourlyPrice      Int?          @map("single_hourly_price")
  multiplayerHourlyPrice Int?          @map("multiplayer_hourly_price")

  // Status & Visibility
  status       DeviceStatus @default(available)
  isVipRoom    Boolean      @default(false) @map("is_vip_room")
  maxPlayers   Int          @default(1) @map("max_players")
  imageUrl     String?      @map("image_url")

  // Stats & Meta
  totalBookings Int     @default(0) @map("total_bookings")
  isActive      Boolean @default(true) @map("is_active")
  displayOrder  Int     @default(0) @map("display_order")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  games DeviceGame[]

  @@map("devices")
  @@index([branchId, status, isActive])
  @@index([shopId, deviceType])
  @@index([status])
}

model Game {
  id          String   @id @default(uuid())

  // Basic Info
  title       String
  titleAr     String?  @map("title_ar")
  categoryId  Int      @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  description   String?
  coverImageUrl String? @map("cover_image_url")
  isActive      Boolean @default(true) @map("is_active")
  displayOrder  Int     @default(0) @map("display_order")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  devices DeviceGame[]

  @@map("games")
  @@index([categoryId, isActive])
}

// Many-to-Many: Devices <-> Games
model DeviceGame {
  deviceId String @map("device_id")
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  gameId String @map("game_id")
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now()) @map("added_at")

  @@id([deviceId, gameId])
  @@map("device_games")
  @@index([deviceId])
  @@index([gameId])
}

model CoinTransaction {
  id              Int                    @id @default(autoincrement())
  amount          Int
  userId          Int                    @map("user_id")
  description     TransactionDescription
  transactionType TransactionType        @map("transaction_type")
  createdAt       DateTime               @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("coin_transactions")
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  imageUrl     String?  @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  locale       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  games Game[]

  @@map("categories")
}

enum Role {
  USER
  SUPER_ADMIN
  SHOP_ADMIN
}

enum DeviceType {
  PS4
  PS5
  VIP_PS5
  Xbox_Series_X
  Gaming_PC
}

enum DeviceStatus {
  available
  busy
  offline
  maintenance
}

enum TransactionType {
  Debit
  Credit
}

enum TransactionDescription {
  New_User     @map("New user")
  Daily_Reward @map("Daily Reward")
  Ad_Reward    @map("Ad Reward")
  Booking
}

enum SubscriptionStatus {
  trial
  active
  expired
  cancelled
}

enum SubscriptionPlan {
  basic
  pro
  enterprise
}
